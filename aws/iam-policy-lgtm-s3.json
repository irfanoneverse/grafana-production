{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "LGTMStackS3Access",
      "Effect": "Allow",
      "Action": [
        "s3:PutObject",
        "s3:GetObject",
        "s3:DeleteObject",
        "s3:ListBucket",
        "s3:GetBucketLocation"
      ],
      "Resource": [
        "arn:aws:s3:::YOUR_COMPANY-observability-data",
        "arn:aws:s3:::YOUR_COMPANY-observability-data/*"
      ]
    }
  ]
}
